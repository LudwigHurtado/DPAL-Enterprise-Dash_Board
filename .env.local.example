# ─── DPAL Enterprise Dashboard — Environment Variables ───────────────────────
# Copy this file to .env.local (never commit .env.local to git).
# On Vercel: add these in Project → Settings → Environment Variables.

# ─── Backend base URL (Railway, Render, or local dev) ────────────────────────
# This is the root of your dpal-front-end/backend Express server.
# No trailing slash.
NEXT_PUBLIC_DPAL_API_BASE="https://your-backend.up.railway.app"

# For local development against the backend running on port 3001:
# NEXT_PUBLIC_DPAL_API_BASE="http://localhost:3001"

# ─── Admin secret ─────────────────────────────────────────────────────────────
# Must match the ADMIN_SECRET in the backend .env.
# Used as Bearer token for /api/admin/* endpoints.
NEXT_PUBLIC_DPAL_ADMIN_SECRET="change-this-in-production"

# ─── Optional: Supabase (if dashboard calls Supabase directly) ────────────────
# Usually the dashboard talks to the backend API, not Supabase directly.
# Only needed if you add server-side Supabase calls to Next.js API routes.
# NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
